function make_pair(start) {
    let count = start
    let inc = function() {
        count = count + 1
        return count
    }
    let get = function() {
        return count
    }
    return inc, get
}

function use_pair() {
    let inc, get = make_pair(2)
    print(get())
    print(inc())
    print(get())
}

use_pair()
