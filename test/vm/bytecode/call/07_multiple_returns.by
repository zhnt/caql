# 07_multiple_returns.by
# 测试: 真正的多个返回值函数
# 预期结果: 5 (3 + 2 ，商+余数)

.main
.code
CLOSURE   R0, 0            # R0 = function <divmod>
LOADI     R1, 17           # R1 = 17 (被除数)
LOADI     R2, 5            # R2 = 5 (除数)
CALL      R0, 3, 3         # 调用divmod(17, 5), 2个参数, 期望2个返回值
# 调用后: R0 = 商(3), R1 = 余数(2)
ADD       R3, R0, R1       # R3 = 商 + 余数 = 3 + 2 = 5
MMBIN     R0, R1, 6        # 元方法处理 (__add)
RETURN1   R3               # 返回结果
.end

.function divmod 2
.code
# R0 = dividend, R1 = divisor
# 计算商和余数
DIV       R2, R0, R1       # R2 = dividend / divisor (商)
MMBIN     R0, R1, 11       # 元方法处理 (__div)
MOD       R3, R0, R1       # R3 = dividend % divisor (余数)  
MMBIN     R0, R1, 9        # 元方法处理 (__mod)
# 返回两个值: 商和余数 (像Lua一样先MOVE再RETURN)
MOVE      R4, R2           # R4 = 商
MOVE      R5, R3           # R5 = 余数
RETURN    R4, 3, 0         # 从R4开始返回2个值 (R4, R5)
.end
