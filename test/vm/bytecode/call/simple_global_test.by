# simple_global_test.by
# 测试简单的全局变量操作，不使用闭包

.main
K0 STRING "x"
K1 STRING "y"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
# 设置全局变量
LOADI     R0, 10          # R0 = 10
SETTABUP  0, K0, R0       # _ENV["x"] = 10

LOADI     R1, 20          # R1 = 20
SETTABUP  0, K1, R1       # _ENV["y"] = 20

# 获取全局变量
GETTABUP  R2, 0, K0       # R2 = _ENV["x"]
GETTABUP  R3, 0, K1       # R3 = _ENV["y"]

# 计算 x + y
ADD       R4, R2, R3      # R4 = R2 + R3
MMBIN     R4, R3, 6       # __add 元方法
RETURN1   R4              # 返回结果 (应该是30)
.end

.function helper 0
.code
RETURN0
.end
