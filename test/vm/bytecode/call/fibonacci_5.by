# fibonacci_5.by
# 测试递归斐波那契数列: fib(5) = 5
# 实现 fib(n) = n <= 1 ? n : fib(n-1) + fib(n-2)

.main
K0 STRING "fib"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
CLOSURE   R0, 0            # R0 = fib函数
SETTABUP  0, K0, R0        # _ENV["fib"] = R0

# 调用fib(5)
GETTABUP  R1, 0, K0        # R1 = _ENV["fib"]  
LOADI     R2, 5            # R2 = 5 (参数)
CALL      R1, 2, 2         # fib(5), 1个参数, 1个返回值
RETURN1   R1               # 返回结果
.end

.function fib 1
K0 STRING "fib"
.upvalues 1
.upvalue 0 "_ENV" upval 0
.code
# R0 = n (参数)
# 基础情况: 如果 n <= 1，返回 n
LEI       R0, 1, 0         # n <= 1? 如果为真跳过JMP，为假执行JMP
JMP       1                # 跳转到递归情况

# 基础情况: 返回 n
RETURN1   R0               # return n

# 递归情况: return fib(n-1) + fib(n-2)
# 先保存原始n值
MOVE      R5, R0           # R5 = n (保存原始值)

# 计算 fib(n-1)
GETTABUP  R1, 0, K0        # R1 = _ENV["fib"]
ADDI      R2, R0, -1       # R2 = n - 1
MMBINI    R0, 1, 7, 0      # __sub 元方法: R0 - 1, TM_SUB=7, flip=0
CALL      R1, 2, 2         # fib(n-1)，参数在R2，结果到R1

# 计算 fib(n-2) 
GETTABUP  R3, 0, K0        # R3 = _ENV["fib"]
ADDI      R4, R0, -2       # R4 = n - 2 (使用原始的R0)
MMBINI    R0, 2, 7, 0      # __sub 元方法: R0 - 2, TM_SUB=7, flip=0
CALL      R3, 2, 2         # fib(n-2)，参数在R4，结果到R3

# 计算 fib(n-1) + fib(n-2)
ADD       R6, R1, R3       # R6 = fib(n-1) + fib(n-2)
MMBIN     R1, R3, 6        # __add 元方法（操作数R1,R3，结果到R6）
RETURN1   R6               # return fib(n-1) + fib(n-2)
.end
