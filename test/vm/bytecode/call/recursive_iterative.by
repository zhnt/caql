# recursive_iterative.by  
# 测试: 迭代式计算而非递归（避免条件跳转）
# 预期结果: 15 (1+2+3+4+5的累加和)

.main
.code
CLOSURE   R0, 0            # R0 = function <sum_iterative>
LOADI     R1, 5            # R1 = 5 (计算1到5的和)
CALL      R0, 2, 2         # 调用sum_iterative(5)
RETURN1   R0               # 返回结果
.end

.function sum_iterative 1
.code
# R0 = n (参数)
# 使用公式计算: n * (n + 1) / 2
LOADI     R1, 1            # R1 = 1
ADD       R2, R0, R1       # R2 = n + 1
MMBIN     R0, R1, 6        # 元方法处理 (__add)
MUL       R3, R0, R2       # R3 = n * (n + 1)
MMBIN     R0, R2, 8        # 元方法处理 (__mul)
LOADI     R4, 2            # R4 = 2
DIV       R5, R3, R4       # R5 = n * (n + 1) / 2
MMBIN     R3, R4, 9        # 元方法处理 (__div)
RETURN1   R5               # 返回结果
.end
