# 05_multiple_parameters.by
# 测试: 多个参数函数
# 预期结果: 60 (3 * 4 * 5)

.main
.code
CLOSURE   R0, 0            # R0 = function <multiply3>
LOADI     R1, 3            # R1 = 3 (参数1)
LOADI     R2, 4            # R2 = 4 (参数2)  
LOADI     R3, 5            # R3 = 5 (参数3)
CALL      R0, 4, 2         # 调用multiply3(3, 4, 5), 3个参数, 1个返回值
RETURN1   R0               # 返回结果
.end

.function multiply3 3
.code
# R0 = a, R1 = b, R2 = c
MUL       R3, R0, R1       # R3 = a * b
MMBIN     R0, R1, 8        # 元方法处理 (__mul)
MUL       R4, R3, R2       # R4 = (a * b) * c
MMBIN     R3, R2, 8        # 元方法处理 (__mul)
RETURN1   R4               # 返回R4
.end
