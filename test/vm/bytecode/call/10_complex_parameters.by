# 10_complex_parameters.by
# 测试: 复杂参数传递（函数结果作为参数）
# 预期结果: 14 (add(square(3), sub(8, 3)) = add(9, 5) = 14)

.main
.code
CLOSURE   R0, 0            # R0 = function <square>
CLOSURE   R1, 1            # R1 = function <sub>
CLOSURE   R2, 2            # R2 = function <add>

# 计算square(3)
LOADI     R3, 3            # R3 = 3
MOVE      R4, R0           # R4 = square函数
MOVE      R5, R3           # R5 = 参数3
CALL      R4, 2, 2         # 调用square(3), 结果在R4 (9)

# 计算sub(8, 3)
LOADI     R6, 8            # R6 = 8
LOADI     R7, 3            # R7 = 3
MOVE      R8, R1           # R8 = sub函数
MOVE      R9, R6           # R9 = 参数8
MOVE      R10, R7          # R10 = 参数3
CALL      R8, 3, 2         # 调用sub(8, 3), 结果在R8 (5)

# 计算add(square_result, sub_result)
MOVE      R11, R2          # R11 = add函数
MOVE      R12, R4          # R12 = square结果 (9)
MOVE      R13, R8          # R13 = sub结果 (5)
CALL      R11, 3, 2        # 调用add(9, 5), 结果在R11 (14)

RETURN1   R11              # 返回最终结果
.end

.function square 1
.code
MUL       R1, R0, R0       # R1 = x * x
MMBIN     R0, R0, 8        # 元方法处理 (__mul)
RETURN1   R1               # 返回R1
.end

.function sub 2
.code
SUB       R2, R0, R1       # R2 = R0 - R1
MMBIN     R0, R1, 7        # 元方法处理 (__sub)
RETURN1   R2               # 返回R2
.end

.function add 2
.code
ADD       R2, R0, R1       # R2 = R0 + R1
MMBIN     R0, R1, 6        # 元方法处理 (__add)
RETURN1   R2               # 返回R2
.end
