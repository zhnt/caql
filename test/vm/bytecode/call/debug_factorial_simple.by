# debug_factorial_simple.by
# 简单的factorial(3)测试，手动展开递归
# 预期结果: 6

.main
K0 STRING "factorial"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
CLOSURE   R0, 0            # R0 = factorial函数
SETTABUP  0, K0, R0        # _ENV["factorial"] = R0
GETTABUP  R1, 0, K0        # R1 = _ENV["factorial"]  
LOADI     R2, 3            # R2 = 3 (参数)
CALL      R1, 2, 2         # factorial(3)
RETURN1   R1               # 返回结果
.end

.function factorial 1
K0 STRING "factorial"
.upvalues 1
.upvalue 0 "_ENV" upval 0
.code
# R0 = n (参数)
# 基础情况: 如果 n <= 1，返回 1
LEI       R0, 1, 0         # n <= 1? 
JMP       2                # 如果n > 1，跳转到递归情况

LOADI     R1, 1            # R1 = 1 (基础情况)
RETURN1   R1               # return 1

# 递归情况: factorial(n) = n * factorial(n-1)
MOVE      R5, R0           # R5 = n (保存原始值)
GETTABUP  R1, 0, K0        # R1 = _ENV["factorial"]
ADDI      R2, R0, -1       # R2 = n - 1 
CALL      R1, 2, 2         # 递归调用 factorial(n-1)，参数在R2，结果到R1
MUL       R6, R5, R1       # R6 = n * factorial(n-1) (R5=原始n, R1=递归结果)
RETURN1   R6               # 返回结果
.end

