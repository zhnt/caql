# 02_multiple_functions.by
# 测试: 多个独立函数调用
# 预期结果: 13 (add(5, 3) + sub(8, 3))

.main
.code
# 调用add函数
CLOSURE   R0, 0            # R0 = function <add>
LOADI     R1, 5            # R1 = 5
LOADI     R2, 3            # R2 = 3
CALL      R0, 3, 2         # 调用add(5, 3)
MOVE      R3, R0           # R3 = add结果 (8)

# 调用sub函数
CLOSURE   R4, 1            # R4 = function <sub>
LOADI     R5, 8            # R5 = 8
LOADI     R6, 3            # R6 = 3
CALL      R4, 3, 2         # 调用sub(8, 3)
MOVE      R7, R4           # R7 = sub结果 (5)

# 将两个结果相加
ADD       R8, R3, R7       # R8 = 8 + 5 = 13
MMBIN     R3, R7, 6        # 元方法处理 (__add)
RETURN1   R8               # 返回最终结果
.end

.function add 2
.code
ADD       R2, R0, R1       # R2 = R0 + R1
MMBIN     R0, R1, 6        # 元方法处理 (__add)
RETURN1   R2               # 返回R2
.end

.function sub 2
.code
SUB       R2, R0, R1       # R2 = R0 - R1
MMBIN     R0, R1, 7        # 元方法处理 (__sub)
RETURN1   R2               # 返回R2
.end
