# recursive_simple_fixed.by
# 测试: 修复的简单递归（避免CLOSURE重复创建）
# 预期结果: 0 (countdown(2) = 0)

.main
K0 STRING "countdown"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
CLOSURE   R0, 0            # R0 = function <countdown>
SETTABUP  0, K0, R0        # 递归通过_ENV回调，避免重复创建闭包
GETTABUP  R1, 0, K0
LOADI     R2, 2
CALL      R1, 2, 2
RETURN1   R1
.end

.function countdown 1
.upvalues 1
.upvalue 0 "_ENV" upval 0
.constants
K0 STRING "countdown"
.code
# R0 = n (参数)
# 基础情况: 如果 n <= 0，返回 0
LEI       R0, 0, 0
JMP       3
LOADI     R1, 0
RETURN1   R1
JMP       7

# 递归情况: countdown(n-1)
GETTABUP  R1, 0, K0
ADDI      R2, R0, -1
MMBINI    R0, 1, 7, 0
CALL      R1, 2, 2
RETURN1   R1
.end
