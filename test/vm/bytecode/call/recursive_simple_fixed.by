# recursive_simple_fixed.by
# 测试: 修复的简单递归（避免CLOSURE重复创建）
# 预期结果: 0 (countdown(2) = 0)

.main
.code
CLOSURE   R0, 0            # R0 = function <countdown>
LOADI     R1, 2            # R1 = 2 (从2开始倒数)
CALL      R0, 2, 2         # 调用countdown(2)
RETURN1   R0               # 返回结果
.end

.function countdown 1
.upvalues 1
.upvalue 0 "self" instack 0    # upvalue[0] = 函数自身引用
.code
# R0 = n (参数)
# 基础情况: 如果 n <= 0，返回 0
LOADI     R1, 0            # R1 = 0
LE        R0, R1, 0        # 比较 R0 <= R1，如果成立则跳转
JMP       0, 2             # 跳过返回0的指令
RETURN1   R1               # 返回0 (基础情况)

# 递归情况: countdown(n-1)
GETUPVAL  R2, 0            # R2 = upvalue[0] (函数自身)
LOADI     R3, 1            # R3 = 1
SUB       R4, R0, R3       # R4 = n - 1
MMBIN     R0, R3, 7        # 元方法处理 (__sub)
MOVE      R5, R4           # R5 = n - 1 (参数)
TAILCALL  R2, 2, 0         # 尾递归调用 countdown(n-1)
RETURN    R2, 0, 0         # 返回尾调用结果
.end


