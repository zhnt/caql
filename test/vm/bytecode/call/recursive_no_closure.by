# recursive_no_closure.by
# 测试: 避免在递归中使用CLOSURE
# 预期结果: 计算阶乘但避免段错误

.main
K0 STRING "simple_factorial"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
CLOSURE   R0, 0            # R0 = function <simple_factorial>
SETTABUP  0, K0, R0        # 只创建一次闭包，递归时从_ENV取回
GETTABUP  R1, 0, K0
LOADI     R2, 3
CALL      R1, 2, 2
RETURN1   R1
.end

.function simple_factorial 1
.upvalues 1
.upvalue 0 "_ENV" upval 0
.constants
K0 STRING "simple_factorial"
.code
# R0 = n (参数)
# 基础情况: 如果 n <= 1，返回 1
LEI       R0, 1, 0
JMP       3
LOADI     R1, 1
RETURN1   R1
JMP       7
GETTABUP  R1, 0, K0
ADDI      R2, R0, -1
MMBINI    R0, 1, 7, 0
CALL      R1, 2, 2
MUL       R3, R0, R1
MMBIN     R0, R1, 13
RETURN1   R3
.end
