# aql_counter_closure.by
# AQL闭包示例：独立计数器
# 基于Lua的makeCounter例子
# 预期结果: 11 (第一个计数器从10开始)

.main
K0 STRING "makeCounter"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
CLOSURE   R0, 0            # R0 = makeCounter函数
SETTABUP  0, K0, R0        # _ENV["makeCounter"] = R0

# 创建第一个计数器：counter1 = makeCounter(10)
GETTABUP  R1, 0, K0        # R1 = _ENV["makeCounter"]
LOADI     R2, 10           # R2 = 10 (起始值)
CALL      R1, 2, 2         # makeCounter(10)，返回闭包到R1

# 调用counter1() - 第一次
CALL      R1, 1, 2         # counter1()，应该返回11
RETURN1   R1               # 返回结果
.end

.function makeCounter 1
.code
# R0 = start (起始值参数)
MOVE      R1, R0           # R1 = start (这将成为upvalue)
CLOSURE   R2, 0            # R2 = counter函数 (会捕获R1作为upvalue)
RETURN1   R2               # 返回counter函数
.end

.function counter 0
.upvalues 1
.upvalue 0 "count" instack 1    # upvalue[0] = 外层函数的R1 (count)
.code
# 无参数，返回递增后的计数
GETUPVAL  R0, 0            # R0 = upvalue[0] (count)
ADDI      R1, R0, 1        # R1 = count + 1
MMBINI    R0, 1, 6, 0      # __add 元方法
SETUPVAL  R1, 0            # upvalue[0] = R1 (更新count)
RETURN1   R1               # 返回新的count值
.end
