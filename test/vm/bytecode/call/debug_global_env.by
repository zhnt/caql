# 测试全局环境设置

.main 
.upvalues 1
.upvalue 0 "_ENV" instack 0
.constants
K0 STRING "countdown"
.code
# 创建全局环境表
NEWTABLE  R1, 0, 1
EXTRAARG  0
SETUPVAL  R1, 0

# 创建一个简单函数并放入全局环境
CLOSURE   R2, 0       
SETTABUP  0, K0, R2   # _ENV["countdown"] = function

# 尝试从全局环境获取函数并调用（带参数）
GETTABUP  R3, 0, K0   # R3 = _ENV["countdown"]
LOADI     R4, 5       # R4 = 5 (参数)
CALL      R3, 2, 2    # 调用函数，1个参数，1个返回值
RETURN1   R3          # 返回调用结果，应该是5+42=47
.end

.function countdown 1
.upvalues 1
.upvalue 0 "_ENV" instack 0
.constants  
K0 INTEGER 42
.code
# 接受参数并返回 参数 + 42
LOADK     R1, K0      # R1 = 42
ADD       R1, R0, R1  # R1 = 参数 + 42
MMBIN     R0, R1, 6   # ADD的元方法绑定
RETURN1   R1                    
.end
