# counter_closure_demo.by
# 完整的计数器闭包演示
# 展示闭包的独立状态特性

.main
K0 STRING "makeCounter"
K1 STRING "counter1"
K2 STRING "counter2"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
CLOSURE   R0, 0            # R0 = makeCounter函数
SETTABUP  0, K0, R0        # _ENV["makeCounter"] = R0

# 创建第一个计数器：counter1 = makeCounter(10)
GETTABUP  R1, 0, K0        # R1 = _ENV["makeCounter"]
LOADI     R2, 10           # R2 = 10
CALL      R1, 2, 2         # makeCounter(10)
SETTABUP  0, K1, R1        # _ENV["counter1"] = R1

# 创建第二个计数器：counter2 = makeCounter(100)
GETTABUP  R1, 0, K0        # R1 = _ENV["makeCounter"]
LOADI     R2, 100          # R2 = 100
CALL      R1, 2, 2         # makeCounter(100)
SETTABUP  0, K2, R1        # _ENV["counter2"] = R1

# 测试counter1() - 应该返回11
GETTABUP  R1, 0, K1        # R1 = _ENV["counter1"]
CALL      R1, 1, 2         # counter1()
RETURN1   R1               # 返回结果 (应该是11)
.end

.function makeCounter 1
.code
# R0 = start (起始值)
MOVE      R1, R0           # R1 = start (准备作为upvalue)
CLOSURE   R2, 0            # R2 = counter函数
RETURN1   R2               # 返回counter函数
.end

.function counter 0
.upvalues 1
.upvalue 0 "count" instack 1    # upvalue[0] = 外层的R1 (count)
.code
# 按照Lua的模式：GETUPVAL -> ADDI -> MMBINI -> SETUPVAL -> GETUPVAL -> RETURN1
GETUPVAL  R0, 0            # R0 = upvalue[0] (count)
ADDI      R0, R0, 1        # R0 = count + 1
MMBINI    R0, 1, 6, 0      # __add 元方法
SETUPVAL  R0, 0            # upvalue[0] = R0 (更新count)
GETUPVAL  R0, 0            # R0 = upvalue[0] (获取更新后的值)
RETURN1   R0               # 返回递增后的值
.end
