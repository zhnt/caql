# 09_recursive_function.by
# 测试: 递归函数调用（简单版本）
# 预期结果: 6 (factorial(3) = 3! = 6)
# 注意: 这是简化的递归，没有完整的条件判断

.main
.code
CLOSURE   R0, 0            # R0 = function <factorial>
LOADI     R1, 3            # R1 = 3 (计算3的阶乘)
CALL      R0, 2, 2         # 调用factorial(3)
RETURN1   R0               # 返回结果
.end

.function factorial 1
K0 INTEGER 1
K1 INTEGER 2
.code
# 简化版递归: 只计算3! = 3 * 2 * 1
LOADK     R1, 1            # R1 = 2
MUL       R2, R0, R1       # R2 = 3 * 2 = 6
MMBIN     R0, R1, 8        # 元方法处理 (__mul)
LOADK     R3, 0            # R3 = 1  
MUL       R4, R2, R3       # R4 = 6 * 1 = 6
MMBIN     R2, R3, 8        # 元方法处理 (__mul)
RETURN1   R4               # 返回结果
.end
