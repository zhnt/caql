# recursive_global_style.by
# 测试: 基于Lua全局环境模式的递归
# 预期结果: 6 (3! = 6)

.main
.code
# 模拟设置全局函数
CLOSURE   R0, 0            # R0 = function <factorial>
# 直接调用，不设置全局（简化版）
LOADI     R1, 3            # R1 = 3
CALL      R0, 2, 2         # 调用factorial(3)
RETURN1   R0               # 返回结果
.end

.function factorial 1
K0 STRING "factorial"
.code
# R0 = n (参数)
# 基础情况: 如果 n <= 1，返回 1
LOADI     R1, 1            # R1 = 1
LE        R0, R1, 0        # 比较 R0 <= R1，如果为真则跳转到基础情况
JMP       0, 2             # 跳过递归分支
# 递归情况: 计算 n * factorial(n-1)
# 这里我们先简化，只计算 n - 1，不做真正的递归
LOADI     R2, 1            # R2 = 1
SUB       R3, R0, R2       # R3 = n - 1
MMBIN     R0, R2, 7        # 元方法处理 (__sub)
# 暂时返回 n-1 而不是递归调用，避免段错误
RETURN1   R3               # 返回 n-1 (简化版)
JMP       0, 1             # 跳过基础情况
# 基础情况
RETURN1   R1               # 返回1
.end

