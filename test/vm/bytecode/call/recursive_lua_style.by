# recursive_lua_style.by
# 测试: 基于Lua模式的递归实现
# 预期结果: 0 (countdown(3) = 0)

.main
K0 STRING "countdown"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
# 设置全局函数
CLOSURE   R0, 0            # R0 = function <countdown>
SETTABUP  0, K0, R0        # _ENV["countdown"] = function

# 调用函数
GETTABUP  R1, 0, K0        # R1 = _ENV["countdown"]
LOADI     R2, 3            # R2 = 3
CALL      R1, 2, 2         # 调用countdown(3)
RETURN1   R1               # 返回结果
.end

.function countdown 1
K0 STRING "countdown"
.upvalues 1
.upvalue 0 "_ENV" upval 0
.code
# R0 = n (参数)
# 基础情况: 如果 n <= 0，返回 0
LEI       R0, 0, 0
JMP       3
LOADI     R1, 0
RETURN1   R1
JMP       6

# 递归情况: countdown(n-1)
GETTABUP  R1, 0, K0        # R1 = _ENV["countdown"]
ADDI      R2, R0, -1       # R2 = n - 1
MMBINI    R0, 1, 7, 0      # __sub 元方法
TAILCALL  R1, 2, 0         # 尾递归调用 countdown(n-1)
RETURN    R1, 0, 0         # 返回尾调用结果
.end
