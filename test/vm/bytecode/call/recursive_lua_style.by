# recursive_lua_style.by
# 测试: 基于Lua模式的递归实现
# 预期结果: 0 (countdown(3) = 0)

.main
.code
# 设置全局函数
CLOSURE   R0, 0            # R0 = function <countdown>
SETTABUP  0, 0, R0         # _ENV["countdown"] = function

# 调用函数
GETTABUP  R1, 0, 0         # R1 = _ENV["countdown"]
LOADI     R2, 3            # R2 = 3
CALL      R1, 2, 2         # 调用countdown(3)
RETURN1   R1               # 返回结果
.end

.function countdown 1
K0 STRING "countdown"
.code
# R0 = n (参数)
# 基础情况: 如果 n <= 0，返回 0
LOADI     R1, 0            # R1 = 0
LE        R0, R1, 0        # 比较 R0 <= R1，如果成立则跳转
JMP       0, 2             # 跳过返回0的指令
RETURN1   R1               # 返回0 (基础情况)

# 递归情况: countdown(n-1)
GETTABUP  R2, 0, 0         # R2 = _ENV["countdown"] (从全局获取函数)
LOADI     R3, 1            # R3 = 1
SUB       R4, R0, R3       # R4 = n - 1
MMBIN     R0, R3, 7        # 元方法处理 (__sub)
MOVE      R5, R4           # R5 = n - 1 (参数)
TAILCALL  R2, 2, 0         # 尾递归调用 countdown(n-1)
RETURN    R2, 0, 0         # 返回尾调用结果
.end


