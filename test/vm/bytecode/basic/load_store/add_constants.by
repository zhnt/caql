# ADD指令与常量测试
# 测试: ADD指令是否能正确处理寄存器+常量

.constants
K0 INTEGER 5
K1 INTEGER 42

.code
LOADI  R0, 3        # R0 = 3
LOADK  R3, K0       # R3 = 5 (从常量表加载)
ADD    R1, R0, R3   # R1 = 3 + 5 = 8
MMBIN  R1, R0, 6    # 元方法调用 (对结果R1)
LOADK  R4, K1       # R4 = 42 (从常量表加载)  
ADD    R2, R1, R4   # R2 = 8 + 42 = 50
MMBIN  R2, R1, 6    # 元方法调用 (对结果R2)
RETURN1 R2          # 返回 50
.end
