# 常量表边界测试
# 测试: 常量表的不同索引访问

.constants
K0 INTEGER 1
K1 INTEGER 2  
K2 INTEGER 4
K3 INTEGER 8
K4 INTEGER 16

.code
LOADK R4, K0       # R4 = 1
LOADK R5, K1       # R5 = 2
ADD   R0, R4, R5   # R0 = 1 + 2 = 3
MMBIN R0, R4, 6    # 元方法调用
LOADK R6, K2       # R6 = 4
LOADK R7, K3       # R7 = 8
ADD   R1, R6, R7   # R1 = 4 + 8 = 12  
MMBIN R1, R6, 6    # 元方法调用
ADD   R2, R0, R1   # R2 = 3 + 12 = 15
MMBIN R2, R0, 6    # 元方法调用
LOADK R8, K4       # R8 = 16
ADD   R3, R2, R8   # R3 = 15 + 16 = 31
MMBIN R3, R2, 6    # 元方法调用
RETURN1 R3         # 返回 31
.end
