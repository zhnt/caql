# 小于比较测试
# 测试: 3 < 5 为真

.code
LOADI   R0, 3       # R0 = 3
LOADI   R1, 5       # R1 = 5
LT      R0, R1, 0   # 比较 R0 < R1，如果为真则跳过JMP
JMP     2           # 跳转到失败分支
LOADI   R2, 1       # R2 = 1 (如果比较成功)
JMP     1           # 跳过失败分支
LOADI   R2, 0       # R2 = 0 (如果比较失败)
RETURN1 R2          # 返回 R2 (应该是 1)
.end
