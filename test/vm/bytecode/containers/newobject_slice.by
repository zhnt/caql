# NEWOBJECT指令测试 - 创建AQL切片容器
# 测试: 创建slice容器并使用append方法

.code
NEWOBJECT R0, 1, 4   # 创建 slice (类型1=CONTAINER_SLICE, 初始容量4)
LOADI     R1, 100    # R1 = 100
INVOKE    R2, R0, 0  # R2 = R0.append(R1) (方法0=append)
LOADI     R3, 0      # R3 = 0 (索引)
GETPROP   R4, R0, R3 # R4 = R0[0] (应该是100)
RETURN1   R4         # 返回 R4
.end

