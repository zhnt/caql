# 数组乘法元方法测试
# 测试: [2, 3] * [4, 5] 触发 __mul，结果数组的第1个元素为 15

.code
NEWOBJECT R0, 0, 2
LOADI     R10, 0
LOADI     R11, 1
LOADI     R12, 2
LOADI     R13, 3
SETPROP   R0, R10, R12
SETPROP   R0, R11, R13

NEWOBJECT R1, 0, 2
LOADI     R14, 4
LOADI     R15, 5
SETPROP   R1, R10, R14
SETPROP   R1, R11, R15

MUL       R2, R0, R1
MMBIN     R0, R1, 8   # TM_MUL

GETPROP   R3, R2, R11
RETURN1   R3
.end
