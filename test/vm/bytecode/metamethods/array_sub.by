# 数组减法元方法测试
# 测试: [9, 7] - [4, 2] 触发 __sub，结果数组的第1个元素为 5

.code
NEWOBJECT R0, 0, 2
LOADI     R10, 0
LOADI     R11, 1
LOADI     R12, 9
LOADI     R13, 7
SETPROP   R0, R10, R12
SETPROP   R0, R11, R13

NEWOBJECT R1, 0, 2
LOADI     R14, 4
LOADI     R15, 2
SETPROP   R1, R10, R14
SETPROP   R1, R11, R15

SUB       R2, R0, R1
MMBIN     R0, R1, 7   # TM_SUB

GETPROP   R3, R2, R11
RETURN1   R3
.end
