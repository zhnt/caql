# 简单数值 for 循环测试
# for i = 1, 5 {
#     sum = sum + i
# }
# return sum
# 期望结果: 15 (1+2+3+4+5)
# 参考 for_simple.luaby 字节码

.code
LOADI R0, 0          # sum = 0
LOADI R1, 1          # 内部索引 = 1
LOADI R2, 5          # 限制值 = 5  
LOADI R3, 1          # 步长 = 1
FORPREP R1, 2        # 准备 for 循环，跳转到 PC+2=6
ADD R0, R0, R4       # sum = sum + i (R4 是控制变量)
MMBIN R0, R4, 6      # __add metamethod
FORLOOP R1, 3        # for 循环，跳转到 PC-3=5
RETURN1 R0           # 返回 sum
.end
