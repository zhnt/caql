# 复杂嵌套 while 循环测试
# 测试复杂的 while 循环嵌套和跳转指令
# 外层循环：while i < 4, 内层循环：while j < i
# 期望结果: 4
# 内层循环次数: 0, 1, 2, 3 (随着i的变化而变化)
# 参考 luac -l 生成的字节码

.code
LOADI R0, 0          # i = 0
LTI R0, 4, 0         # if i < 4 then skip next JMP (外层循环条件)
JMP 9                # if i >= 4, jump to RETURN1 (exit outer loop)
LOADI R1, 0          # j = 0 (内层循环初始化)
LT R1, R0, 0         # if j < i then skip next JMP (内层循环条件)
JMP 3                # if j >= i, jump to outer loop increment
ADDI R1, R1, 1       # j = j + 1 (内层循环体)
MMBINI R1, 1, 6, 0   # __add metamethod
JMP -5               # jump back to inner condition check (LT R1, R0, 0)
ADDI R0, R0, 1       # i = i + 1 (外层循环体)
MMBINI R0, 1, 6, 0   # __add metamethod
JMP -11              # jump back to outer condition check (LTI R0, 4, 0)
RETURN1 R0           # return i (should be 4)
.end
