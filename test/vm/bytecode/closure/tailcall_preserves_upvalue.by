# tailcall_preserves_upvalue.by
# 尾递归过程中保留捕获的普通局部 upvalue

.main
K0 STRING "makeWorker"
.upvalues 1
.upvalue 0 "_ENV" instack 0
.code
CLOSURE   R0, 0
SETTABUP  0, K0, R0

GETTABUP  R1, 0, K0
LOADI     R2, 42
CALL      R1, 2, 2

LOADI     R2, 3
CALL      R1, 2, 2
RETURN1   R1
.end

.function makeWorker 1
K0 STRING "worker"
.upvalues 1
.upvalue 0 "_ENV" upval 0
.code
MOVE      R1, R0
CLOSURE   R2, 0
SETTABUP  0, K0, R2
RETURN    R2, 2, 1
.end

.function worker 1
K0 STRING "worker"
.upvalues 2
.upvalue 0 "_ENV" upval 0
.upvalue 1 "base" instack 1
.code
LEI       R0, 0, 0
JMP       2
GETUPVAL  R1, 1
RETURN1   R1
GETTABUP  R1, 0, K0
ADDI      R2, R0, -1
MMBINI    R0, 1, 7, 0
TAILCALL  R1, 2, 0
RETURN    R1, 0, 0
.end
