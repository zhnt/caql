# capture_read_local.by
# 返回闭包读取外层局部变量

.main
.code
CLOSURE   R0, 0
LOADI     R1, 41
CALL      R0, 2, 2
CALL      R0, 1, 2
RETURN1   R0
.end

.function makeReader 1
.code
MOVE      R1, R0
CLOSURE   R2, 0
RETURN    R2, 2, 1
.end

.function reader 0
.upvalues 1
.upvalue 0 "value" instack 1
.code
GETUPVAL  R0, 0
RETURN1   R0
.end
